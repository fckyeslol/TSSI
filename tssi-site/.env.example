# --- Notificación de leads por correo (Resend) ---
# 1. Crea una cuenta gratis en https://resend.com  (regístrate con mateopirela08@gmail.com)
# 2. API Keys -> Create API Key -> copia el valor (empieza por re_)
# 3. Pega la clave abajo y reinicia el servidor.
RESEND_API_KEY=re_pega_tu_clave_aqui

# A dónde llegan las notificaciones de leads.
LEAD_NOTIFY_TO=mateopirela08@gmail.com

# Remitente. Sin dominio verificado, Resend solo permite el sender de pruebas
# onboarding@resend.dev y SOLO puede enviar al correo con el que te registraste.
# Cuando verifiques un dominio en Resend, cámbialo por algo como "TSSI <leads@tudominio.com>".
LEAD_FROM=TSSI Leads <onboarding@resend.dev>

# --- Conexiones (valores por defecto ya funcionan en local) ---
# DATABASE_URL=postgresql://sura:sura@localhost:5433/sura
# OLLAMA_URL=http://localhost:11434
